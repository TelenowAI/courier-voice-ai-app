# ──────────────────────────────────────────────────────────────────────────
# Telenow Courier NDR App — environment
# Copy to `.env` and fill in. NEVER commit the real .env.
# This is a SINGLE-TENANT service (one merchant's config).
# ──────────────────────────────────────────────────────────────────────────

# ── App host ────────────────────────────────────────────────────────────────
# The public HTTPS URL where this app is reachable (no trailing slash).
# In dev, use an ngrok/cloudflared tunnel, e.g. https://abcd-1234.ngrok-free.app
# This is used to build the Telenow webhook target URL and the courier webhook
# URLs you paste into Shiprocket / Delhivery.
HOST=https://your-tunnel.ngrok-free.app
PORT=3000

# ── Telenow API ──────────────────────────────────────────────────────────────
# Base URL of the Telenow public API. Default works for production.
TELENOW_API_BASE=https://api.telenow.ai

# NOTE: the Telenow API key is NOT set here. The merchant pastes their own
# `vai_live_...` key in the in-app settings page (/app). It is stored on disk.

# ── Persistence (stub) ────────────────────────────────────────────────────────
# Directory where the file-based store keeps settings, the callMap, the hook
# secret and NDR records. Swap the whole store for a real DB in production.
DATA_DIR=./data

# ── Phone normalization ───────────────────────────────────────────────────────
# ISO-2 country used to turn local numbers into E.164 (default IN).
DEFAULT_PHONE_COUNTRY=IN

# ── Shiprocket courier webhook (inbound NDR) ──────────────────────────────────
# The token you set in Shiprocket → Settings → API → Webhooks. Shiprocket sends
# it back in the `x-api-key` header on every webhook; we verify it constant-time.
SHIPROCKET_WEBHOOK_TOKEN=

# Optional: Shiprocket account login used ONLY for the OPTIONAL re-attempt API
# (POST /v1/external/ndr/{awb}/action). A Bearer token is minted via
# POST /v1/external/auth/login and cached ~10 days. Leave blank to disable the
# automatic re-attempt call (the requested action is still recorded).
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=

# ── Delhivery courier webhook (inbound NDR) ───────────────────────────────────
# A shared token you configure when registering the Delhivery status push. We
# accept it as ?token=<...> on the webhook URL or an x-delhivery-token header.
DELHIVERY_WEBHOOK_TOKEN=

# Optional: Delhivery API token (Bearer) used ONLY for the OPTIONAL re-attempt /
# NDR-edit API. Leave blank to disable the automatic re-attempt call.
DELHIVERY_API_TOKEN=
